{
  "name": "ibchemni-platform-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate --schema=./schema.prisma && next build",
    "start": "next start",
    "prisma:generate": "prisma generate --schema=./schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=./schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=./schema.prisma",
    "prisma:push": "prisma db push --schema=./schema.prisma",
    "prisma:seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.6",
    "next": "14.2.35",
    "prisma": "^6.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
